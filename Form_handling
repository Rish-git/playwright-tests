#Day 10 Task — Form Handling & Multiple Assertions
'''
Test Scenario:

Navigate to login page
Test with blank username — expect error
Test with blank password — expect error
Test with wrong password — expect error
Test with correct credentials — expect success
'''


from playwright.sync_api import sync_playwright
from datetime import datetime
import time
with sync_playwright() as p:
    browser=p.chromium.launch(headless=False)
    page=browser.new_page()

    test_cases =[
    {"username":"","password":"","expect":"error"},
    {"username":"Admin","password":"","expect":"error"},
    {"username":"Admin","password":"wrong","expect":"error"},
    {"username":"Admin","password":"admin123","expect":"success"}
    ]
    results=[]
    for index,case in enumerate(test_cases,start=1):
        # start from login page
        page.goto("https://opensource-demo.orangehrmlive.com/web/index.php/auth/login", timeout=30000)

        # Fill credentials
        page.get_by_placeholder("Username").fill(case["username"])
        page.get_by_placeholder("Password").fill(case["password"])

        # Click Login
        page.get_by_role("button",name="Login").click()

        # Wait for page
        page.wait_for_load_state("networkidle")
        timestamp=datetime.now().strftime('%Y_%m_%d_%H_%M_%S')
        page.screenshot(path=f"C:/Users/rsingh/Documents/VScodeProject/playwright_test/ss/{index}_login_test_{timestamp}.png")

        # Determine actual result
              
        if page.get_by_text("Required").first.is_visible(timeout=2000):
            actual="error"
        elif page.get_by_text("Invalid credentials").first.is_visible(timeout=2000):
            actual="error"
        elif page.get_by_role("heading", name="Dashboard").is_visible(timeout=2000):
            actual="success"
        else:
            actual="unknown"
        
        results.append({
            "test_num": index,
            "username": case["username"],
            "password": case["password"],
            "expect": case["expect"],
            "actual": actual,
            "passed": actual == case["expect"]
             })
#print all the results
print("\n========== TEST SUMMARY ==========\n")
for r in results:
    print(f"Test {r['test_num']}: Username :  {r['username']} | password :  {r['password']}  |  Expected: {r['expect']} |  Got: {r['actual']} | Passed: {r['passed']}")

